# Copy to `.env` or `.env.local` for local development.
#
# CRITICAL for production: set `VITE_API_URL` in your hosting provider (Netlify, Vercel, etc.)
# at *build* time to your backend origin — NOT the static site URL.
# Example: VITE_API_URL=https://api.yourdomain.com
# If missing, the app will fetch `/api/...` from the CDN and receive HTML instead of JSON.
#
# Hostnames without https:// are normalized to https:// (e.g. api.example.com → https://api.example.com).
# In dev, if unset, defaults to http://localhost:3001.

VITE_API_URL=http://localhost:3001

# Calendly booking URL for the landing page scheduler.
# VITE_CALENDLY_URL=https://calendly.com/your-org/meeting
